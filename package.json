{
  "name": "distraction-redirect",
  "version": "1.0.0",
  "description": "Chrome extension that redirects distracting websites to GitHub",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "generate-icons": "node scripts/generate-icons.js",
    "clean": "rimraf dist",
    "test": "jest",
    "style": "prettier --write \"src/**/*.{ts,tsx}\"",
    "version": "bun -e \"console.log((await Bun.file('package.json').json()).version)\"",
    "name": "bun -e \"console.log((await Bun.file('package.json').json()).name)\"",
    "pack": "bun run clean && bun run build && NAME=$(bun run name) && crx pack ./dist -o $NAME-v$(bun run version).crx -p $NAME.pem"
  },
  "keywords": [],
  "author": "tkow",
  "license": "ISC",
  "devDependencies": {
    "@crxjs/vite-plugin": "beta",
    "@types/chrome": "^0.0.193",
    "@types/jest": "^28.1.6",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "@vitejs/plugin-react": "^4.0.0",
    "jest": "^28.1.3",
    "prettier": "^2.7.1",
    "rimraf": "^3.0.2",
    "ts-jest": "^28.0.7",
    "typescript": "^4.7.4",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "overrides": {
    "undici": "5"
  }
}
